{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sealteamworldwide.github.io/ReleaseSeal/database/schema.json",
  "title": "ReleaseSeal evidence database",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "metadata",
    "trustedCertificates",
    "trustedHelpers",
    "verifiedArtifacts",
    "compromised"
  ],
  "properties": {
    "schemaVersion": { "const": 2 },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "databaseVersion", "releaseDate", "notes"],
      "properties": {
        "name": { "type": "string", "minLength": 1, "maxLength": 200 },
        "databaseVersion": { "type": "string", "pattern": "^[0-9]{4}\\.[0-9]{2}\\.[0-9]{2}\\.[0-9]+$" },
        "releaseDate": { "type": "string", "format": "date" },
        "notes": { "type": "string", "minLength": 1, "maxLength": 1000 }
      }
    },
    "trustedCertificates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "hash", "label", "subject", "expires", "source"],
        "properties": {
          "type": { "enum": ["root-sha256", "leaf-sha256"] },
          "hash": { "$ref": "#/$defs/sha256" },
          "label": { "type": "string", "minLength": 1, "maxLength": 300 },
          "subject": { "type": "string", "minLength": 1, "maxLength": 2000 },
          "expires": { "type": "string", "format": "date-time" },
          "notes": { "type": "string", "minLength": 1, "maxLength": 2000 },
          "source": { "type": "string", "minLength": 1, "maxLength": 2000 }
        }
      }
    },
    "trustedHelpers": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "identifier", "fileName", "caseSensitive", "label", "expectedKind",
          "minimumSize", "maximumSize", "heuristicProfile", "heuristicMaximumSize",
          "sha256", "source"
        ],
        "properties": {
          "identifier": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$", "maxLength": 128 },
          "fileName": { "type": "string", "minLength": 1, "maxLength": 255 },
          "caseSensitive": { "type": "boolean" },
          "label": { "type": "string", "minLength": 1, "maxLength": 512 },
          "expectedKind": { "enum": ["text-script", "plain-text", "mach-o", "regular-file"] },
          "minimumSize": { "type": "integer", "minimum": 0, "maximum": 104857600 },
          "maximumSize": { "type": "integer", "minimum": 0, "maximum": 104857600 },
          "heuristicProfile": { "enum": ["none", "shell-script-risk"] },
          "heuristicMaximumSize": { "type": "integer", "minimum": 0, "maximum": 104857600 },
          "sha256": {
            "type": "array",
            "minItems": 1,
            "maxItems": 256,
            "uniqueItems": true,
            "items": { "$ref": "#/$defs/sha256" }
          },
          "source": { "type": "string", "minLength": 1, "maxLength": 4096 },
          "notes": { "type": "string", "minLength": 1, "maxLength": 8192 }
        }
      }
    },
    "verifiedArtifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "hash", "label", "verifiedAt", "source"],
        "properties": {
          "type": { "enum": ["dmg-sha256", "iso-sha256", "pkg-sha256", "zip-sha256"] },
          "hash": { "$ref": "#/$defs/sha256" },
          "label": { "type": "string", "minLength": 1, "maxLength": 500 },
          "verifiedAt": { "type": "string", "format": "date" },
          "source": { "type": "string", "minLength": 1, "maxLength": 2000 },
          "notes": { "type": "string", "minLength": 1, "maxLength": 2000 }
        }
      }
    },
    "compromised": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "hash", "status", "label"],
        "properties": {
          "type": {
            "enum": [
              "cert-sha1", "cert-sha256", "cert-root-sha1", "cert-leaf-sha1",
              "cert-root-sha256", "cert-leaf-sha256", "dmg-md5", "dmg-sha1",
              "dmg-sha256", "iso-md5", "iso-sha1", "iso-sha256", "pkg-md5", "pkg-sha1", "pkg-sha256", "zip-md5",
              "zip-sha1", "zip-sha256"
            ]
          },
          "hash": { "type": "string", "pattern": "^(?:[0-9a-f]{32}|[0-9a-f]{40}|[0-9a-f]{64})$" },
          "status": { "enum": ["compromised", "revoked"] },
          "label": { "type": "string", "minLength": 1, "maxLength": 2000 },
          "source": { "type": "string", "minLength": 1, "maxLength": 2000 }
        }
      }
    }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
  }
}
